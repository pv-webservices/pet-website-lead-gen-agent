{
  "compilerOptions": {
    "target":                          "ES2020",
    "module":                          "commonjs",
    "lib":                             ["ES2020", "ES2022"],
    "outDir":                          "./dist",
    "rootDir":                         "./",
    "strict":                          true,
    "esModuleInterop":                 true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck":                    true,
    "resolveJsonModule":               true
  },
  "include": ["src/**/*", "scripts/**/*"],
  "exclude": ["node_modules", "dist"]
}
