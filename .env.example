# Anthropic API Key — get from https://console.anthropic.com/account/keys
ANTHROPIC_API_KEY=your_anthropic_key_here

# Apify API Token — get from https://console.apify.com/account/integrations
APIFY_TOKEN=your_apify_token_here

# Path to SQLite database file (relative to project root)
DB_PATH=./db/leads.db

# Optional: override minimum quality thresholds
MIN_RATING=4.5
MIN_REVIEWS=100

# Google Sheets integration (for npm run sheet:push)
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
GOOGLE_SHEET_ID=your_google_spreadsheet_id_here
